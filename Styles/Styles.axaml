<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Zootekni Pro Global Styles - Dark Mode -->
    
    <!-- Window Styles -->
    <Style Selector="Window">
        <Setter Property="Background" Value="#0F0F12"/>
    </Style>
    
    <!-- TextBlock Styles -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#FAFAFA"/>
    </Style>
    
    <Style Selector="TextBlock.heading">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <Style Selector="TextBlock.subheading">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#A1A1AA"/>
    </Style>
    
    <!-- Button Styles -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#6366F1"/>
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#818CF8"/>
    </Style>
    
    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#4F46E5"/>
    </Style>
    
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="#27272A"/>
    </Style>
    
    <Style Selector="Button.success">
        <Setter Property="Background" Value="#10B981"/>
    </Style>
    
    <Style Selector="Button.success:pointerover">
        <Setter Property="Background" Value="#34D399"/>
    </Style>
    
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="#EF4444"/>
    </Style>
    
    <Style Selector="Button.danger:pointerover">
        <Setter Property="Background" Value="#F87171"/>
    </Style>
    
    <!-- TextBox Styles -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#27272A"/>
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#6366F1"/>
    </Style>
    
    <!-- ComboBox Styles -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#27272A"/>
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    
    <!-- Card/Panel Styles -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#18181B"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow" Value="0 4 12 0 #40000000"/>
    </Style>
    
    <Style Selector="Border.card-header">
        <Setter Property="Background" Value="#27272A"/>
        <Setter Property="CornerRadius" Value="12,12,0,0"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>
    
    <!-- Sidebar Styles -->
    <Style Selector="Border.sidebar">
        <Setter Property="Background" Value="#18181B"/>
        <Setter Property="Width" Value="240"/>
    </Style>
    
    <Style Selector="Border.sidebar-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="Border.sidebar-item:pointerover">
        <Setter Property="Background" Value="#27272A"/>
    </Style>
    
    <Style Selector="Border.sidebar-item.selected">
        <Setter Property="Background" Value="#6366F1"/>
    </Style>
    
    <!-- DataGrid Styles -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="#18181B"/>
        <Setter Property="RowBackground" Value="#18181B"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#3F3F46"/>
    </Style>
    
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="#27272A"/>
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    
    <!-- ScrollViewer -->
    <Style Selector="ScrollViewer">
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    
    <!-- ListBox Styles -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#18181B"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    
    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="#FAFAFA"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>
    
    <Style Selector="ListBoxItem:pointerover">
        <Setter Property="Background" Value="#27272A"/>
    </Style>
    
    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="#6366F1"/>
    </Style>

    <!-- ProgressBar -->
    <Style Selector="ProgressBar">
        <Setter Property="Background" Value="#27272A"/>
        <Setter Property="Foreground" Value="#6366F1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Height" Value="8"/>
    </Style>
    
    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="#FAFAFA"/>
    </Style>

    <!-- TabControl -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="#18181B"/>
    </Style>
    
    <Style Selector="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#A1A1AA"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>
    
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="#6366F1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

</Styles>