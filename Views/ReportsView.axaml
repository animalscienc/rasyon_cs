<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="ZootekniPro.App.Views.ReportsView">
    <Grid Background="#0F0F12" Margin="24">
        <ScrollViewer>
            <StackPanel Spacing="24">
                <!-- Header -->
                <TextBlock Text="Raporlar"
                           Classes="heading"
                           FontSize="28"
                           Foreground="#FAFAFA"/>
                
                <!-- Report Options -->
                <Border Background="#18181B" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Rapor Oluştur"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 Foreground="#FAFAFA"/>
                        
                        <!-- Select Ration -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Rasyon Seç:" Foreground="#A1A1AA"/>
                            <ComboBox x:Name="RationComboBox"
                                      ItemsSource="{Binding SavedRations}"
                                      SelectedItem="{Binding SelectedRation}"
                                      Width="300"/>
                        </StackPanel>
                        
                        <!-- Report Type -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Rapor Türü:" Foreground="#A1A1AA"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <RadioButton Content="Tam Rapor"
                                             IsChecked="{Binding IsFullReport}"
                                             GroupName="ReportType"/>
                                <RadioButton Content="Ekonomik Özet"
                                             IsChecked="{Binding !IsFullReport}"
                                             GroupName="ReportType"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Generate Button -->
                        <Button Content="📄 PDF Oluştur"
                                Command="{Binding GenerateReportCommand}"
                                Classes="primary"
                                HorizontalAlignment="Left"
                                Padding="24,12"/>
                        
                        <!-- Status -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#10B981"
                                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>
                
                <!-- Recent Reports -->
                <Border Background="#18181B" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Son Raporlar"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FAFAFA"/>
                        
                        <DataGrid ItemsSource="{Binding RecentReports}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding Date}"/>
                                <DataGridTextColumn Header="Rasyon Adı" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="Hayvan Grubu" Binding="{Binding AnimalGroup}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>