<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZootekniPro.App.ViewModels"
        xmlns:views="using:ZootekniPro.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="ZootekniPro.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Zootekni Pro - Intelligent Rationing"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F12">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- Main Content Area with Navigation -->
        <Grid ColumnDefinitions="240,*"
              IsVisible="{Binding IsLoggedIn}">
            
            <!-- Sidebar Navigation -->
            <Border Grid.Column="0"
                    Background="#18181B"
                    BorderBrush="#3F3F46"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Logo Section -->
                    <Border Grid.Row="0"
                            Padding="16"
                            Background="#18181B"
                            BorderBrush="#3F3F46"
                            BorderThickness="0,0,0,1">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <!-- Logo Icon -->
                                <Border Width="40" Height="40"
                                        Background="#6366F1"
                                        CornerRadius="8">
                                    <TextBlock Text="🐄"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ZOOTEKNİ PRO"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FAFAFA"/>
                                    <TextBlock Text="v5.0"
                                               FontSize="10"
                                               Foreground="#A1A1AA"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Menu -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8">
                        <StackPanel Spacing="4">
                            <Button Command="{Binding NavigateToDashboardCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="{Binding SelectedMenuIndex, Converter={x:Static views:Converters.SelectedBackgroundConverter}, ConverterParameter=0}"
                                    Padding="12,12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="📊" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Gösterge Paneli" VerticalAlignment="Center" Foreground="#FAFAFA"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToFeedLibraryCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🌾" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Yem Kütüphanesi" VerticalAlignment="Center" Foreground="#FAFAFA"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToRationCalculatorCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🧮" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Rasyon Hesapla" VerticalAlignment="Center" Foreground="#FAFAFA"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToReportsCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="📈" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Raporlar" VerticalAlignment="Center" Foreground="#FAFAFA"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToSettingsCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="12,12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ayarlar" VerticalAlignment="Center" Foreground="#FAFAFA"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- User Section -->
                    <Border Grid.Row="2"
                            Padding="16"
                            Background="#18181B"
                            BorderBrush="#3F3F46"
                            BorderThickness="0,1,0,0">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="32" Height="32"
                                        Background="#6366F1"
                                        CornerRadius="16">
                                    <TextBlock Text="👤"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Username}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FAFAFA"/>
                                    <TextBlock Text="Admin"
                                               FontSize="10"
                                               Foreground="#A1A1AA"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Button Content="Çıkış Yap"
                                    Command="{Binding LogoutCommand}"
                                    HorizontalAlignment="Stretch"
                                    Classes="secondary"
                                    Padding="8,4"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                <!-- Header -->
                <Border Grid.Row="0"
                        Background="#18181B"
                        Padding="24,16"
                        BorderBrush="#3F3F46"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   Classes="heading"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Foreground="#FAFAFA"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <ContentControl Grid.Row="1"
                                Content="{Binding CurrentViewModel}"
                                Margin="24"/>
            </Grid>
        </Grid>

        <!-- Login View (when not logged in) -->
        <ContentControl Content="{Binding CurrentViewModel}"
                        IsVisible="{Binding !IsLoggedIn}"/>
    </Grid>
</Window>
