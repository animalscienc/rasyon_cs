<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ZootekniPro.App.App"
             xmlns:local="using:ZootekniPro.App"
             xmlns:views="using:ZootekniPro.App.Views"
             xmlns:vm="using:ZootekniPro.App.ViewModels"
             xmlns:avalonia="using:Avalonia.Controls"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
        <DataTemplate DataType="vm:LoginViewModel">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="vm:FeedLibraryViewModel">
            <views:FeedLibraryView/>
        </DataTemplate>
        <DataTemplate DataType="vm:RationCalculatorViewModel">
            <views:RationCalculatorView/>
        </DataTemplate>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    
    <Application.Resources>
        <ResourceDictionary>
            <!-- Zootekni Pro Color Palette - Linear/Adobe Style Dark Mode -->
            <Color x:Key="BackgroundPrimary">#0F0F12</Color>
            <Color x:Key="BackgroundSecondary">#18181B</Color>
            <Color x:Key="BackgroundTertiary">#27272A</Color>
            <Color x:Key="AccentPrimary">#6366F1</Color>
            <Color x:Key="AccentSecondary">#10B981</Color>
            <Color x:Key="AccentWarning">#F59E0B</Color>
            <Color x:Key="AccentDanger">#EF4444</Color>
            <Color x:Key="TextPrimary">#FAFAFA</Color>
            <Color x:Key="TextSecondary">#A1A1AA</Color>
            <Color x:Key="BorderColor">#3F3F46</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>